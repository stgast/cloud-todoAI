# Frontend Environment Variables
VITE_API_USER_URL=http://localhost:8081
VITE_API_BOOKING_URL=http://localhost:8082

# Backend Environment Variables (для docker-compose)
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=cloud_todoai

# OpenAI Configuration (опціонально для AI features)
OPENAI_API_KEY=your_openai_api_key_here

# JWT Secret (потебує бути довшим у production)
JWT_SECRET=mySecretKeyThatIsAtLeast32CharactersLongForHS256Algorithm
JWT_EXPIRATION_MS=86400000
